{{ define "email.default.subject" -}}
[{{ .Status | toUpper }}{{ if gt (len .Alerts.Firing) 0 }}:{{ len .Alerts.Firing }}{{ end }}] {{ .CommonLabels.alertname }}{{ if .CommonLabels.service }} ({{ .CommonLabels.service }}){{ end }}
{{- end }}

{{ define "email.default.text" -}}
Status: {{ .Status }}
Alert: {{ .CommonLabels.alertname }}
Service: {{ if .CommonLabels.service }}{{ .CommonLabels.service }}{{ else }}n/a{{ end }}
Firing: {{ len .Alerts.Firing }}
Resolved: {{ len .Alerts.Resolved }}

{{ range .Alerts -}}
- {{ .Labels.alertname }} | severity={{ .Labels.severity }}
  summary: {{ .Annotations.summary }}
  description: {{ .Annotations.description }}
  impact: {{ .Annotations.impact }}
  action: {{ .Annotations.action }}
{{ end -}}
{{- end }}

{{ define "email.default.html" -}}
<!doctype html>
<html>
  <body style="margin:0;padding:0;background:#0f172a;color:#e5e7eb;font-family:Arial,sans-serif;">
    <div style="max-width:760px;margin:24px auto;padding:24px;background:#111827;border:1px solid #334155;border-radius:14px;">
      <div style="display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap;">
        <div>
          <div style="font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:#94a3b8;">Alertmanager</div>
          <h2 style="margin:8px 0 0;color:#f8fafc;">{{ .Status | toUpper }} — {{ .CommonLabels.alertname }}</h2>
          <p style="margin:8px 0 0;color:#cbd5e1;">Service: <strong>{{ if .CommonLabels.service }}{{ .CommonLabels.service }}{{ else }}n/a{{ end }}</strong></p>
        </div>
        <div style="padding:10px 14px;border-radius:999px;background:{{ if eq .Status "firing" }}#7f1d1d{{ else }}#14532d{{ end }};color:#fff;font-weight:700;">
          {{ .Status | toUpper }}
        </div>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:20px;">
        <div style="padding:14px;border-radius:12px;background:#1f2937;border:1px solid #334155;">
          <div style="font-size:12px;color:#94a3b8;">Firing</div>
          <div style="font-size:28px;font-weight:700;color:#f8fafc;">{{ len .Alerts.Firing }}</div>
        </div>
        <div style="padding:14px;border-radius:12px;background:#1f2937;border:1px solid #334155;">
          <div style="font-size:12px;color:#94a3b8;">Resolved</div>
          <div style="font-size:28px;font-weight:700;color:#f8fafc;">{{ len .Alerts.Resolved }}</div>
        </div>
        <div style="padding:14px;border-radius:12px;background:#1f2937;border:1px solid #334155;">
          <div style="font-size:12px;color:#94a3b8;">Total</div>
          <div style="font-size:28px;font-weight:700;color:#f8fafc;">{{ len .Alerts }}</div>
        </div>
      </div>

      <div style="margin-top:20px;border:1px solid #334155;border-radius:12px;overflow:hidden;">
        <table style="width:100%;border-collapse:collapse;">
          <thead style="background:#1f2937;">
            <tr>
              <th align="left" style="padding:12px;border-bottom:1px solid #334155;">Alert</th>
              <th align="left" style="padding:12px;border-bottom:1px solid #334155;">Severity</th>
              <th align="left" style="padding:12px;border-bottom:1px solid #334155;">Summary</th>
            </tr>
          </thead>
          <tbody>
          {{ range .Alerts }}
            <tr style="background:#0f172a;">
              <td style="padding:12px;border-bottom:1px solid #334155;vertical-align:top;">{{ .Labels.alertname }}</td>
              <td style="padding:12px;border-bottom:1px solid #334155;vertical-align:top;">{{ .Labels.severity }}</td>
              <td style="padding:12px;border-bottom:1px solid #334155;vertical-align:top;">
                <div style="font-weight:700;color:#f8fafc;">{{ .Annotations.summary }}</div>
                <div style="margin-top:4px;color:#cbd5e1;">{{ .Annotations.description }}</div>
                {{ if .Annotations.action }}<div style="margin-top:8px;color:#93c5fd;">Action: {{ .Annotations.action }}</div>{{ end }}
                {{ if .Annotations.impact }}<div style="margin-top:4px;color:#fca5a5;">Impact: {{ .Annotations.impact }}</div>{{ end }}
              </td>
            </tr>
          {{ end }}
          </tbody>
        </table>
      </div>
    </div>
  </body>
</html>
{{- end }}
